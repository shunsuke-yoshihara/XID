Procedures {
    "multiclock_capture" {
        W "_multiclock_capture_WFT_";
        C {
            "all_inputs" = 0NN0NN;
            "all_outputs" = XXX;
        }
        V {
            "_pi" = \r6 #;
            "_po" = ###;
        }
    }

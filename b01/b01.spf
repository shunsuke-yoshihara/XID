STIL 1.0 {
    Design 2005;
}
Header {
    Title "Minimal STIL for design `b01'";
    Date "Mon Jul  1 17:31:08 2024";
    Source "DFT Compiler U-2022.12-SP4";
}
Signals {
    "clock" In;
    "line1" In;
    "line2" In;
    "reset" In;
    "outp" Out;
    "overflw" Out;
    "test_si" In;
    "test_so" Out;
    "test_se" In;
}
SignalGroups {
    "_si" = '"test_si"' {
        ScanIn;
    }
    "_so" = '"test_so"' {
        ScanOut;
    }
    "_clk" = '"clock" + "reset"';
    "all_inputs" = '"clock" + "line1" + "line2" + "reset" + "test_si" + 
    "test_se"';
    "all_outputs" = '"outp" + "overflw" + "test_so"';
    "all_ports" = '"all_inputs" + "all_outputs"';
    "_pi" = '"clock" + "line1" + "line2" + "reset" + "test_si" + "test_se"';
    "_po" = '"outp" + "overflw" + "test_so"';
}
ScanStructures {
    ScanChain "1" {
        ScanLength 5;
        ScanIn "test_si";
        ScanOut "test_so";
        ScanEnable "test_se";
        ScanMasterClock "clock";
    }
}

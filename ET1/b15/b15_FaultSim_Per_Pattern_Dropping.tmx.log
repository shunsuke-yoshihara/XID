# Add Faults
add_faults -all
 31962 faults were added to fault list.
# Write All Faults Information
#report_faults -all > b14_all_Stack_Faults.flt
exec mkdir -p ${CIRCUIT}/Partitioning_Flt_Dropping_DT/
exec mkdir -p ${CIRCUIT}/Partitioning_Flt_Dropping_PT/
exec mkdir -p ${CIRCUIT}/Partitioning_Flt_Dropping_UD/
exec mkdir -p ${CIRCUIT}/Partitioning_Flt_Dropping_AU/
exec mkdir -p ${CIRCUIT}/Partitioning_Flt_Dropping_AE/
exec mkdir -p ${CIRCUIT}/Partitioning_Flt_Dropping_ND/
for {set n 1} {$n <= ${PATTERNS}} {incr n} {
  if { [expr {$n % 100}] == 0 } {
    puts stderr  "Now = $n Pattern"
    flush stderr
  }
  # Set Patterns
  set_patterns -external ${CIRCUIT}/Partitioning_Stil/${CIRCUIT}_pn${n}.stil


  # Add Not-DT Faults
  if {$n != 1} {
    set LAST_PATTERN [expr {$n - 1}]

    set pt_file ${CIRCUIT}/Partitioning_Flt_Dropping_PT/${CIRCUIT}_pn${LAST_PATTERN}_PT.flt
    set ud_file ${CIRCUIT}/Partitioning_Flt_Dropping_UD/${CIRCUIT}_pn${LAST_PATTERN}_UD.flt
    set au_file ${CIRCUIT}/Partitioning_Flt_Dropping_AU/${CIRCUIT}_pn${LAST_PATTERN}_AU.flt
    set ae_file ${CIRCUIT}/Partitioning_Flt_Dropping_AE/${CIRCUIT}_pn${LAST_PATTERN}_AE.flt
    set nd_file ${CIRCUIT}/Partitioning_Flt_Dropping_ND/${CIRCUIT}_pn${LAST_PATTERN}_ND.flt

    if {[file exists $pt_file] && [file size $pt_file] > 0} {
        read_faults $pt_file
    }

    if {[file exists $ud_file] && [file size $ud_file] > 0} {
        read_faults $ud_file
    }

    if {[file exists $au_file] && [file size $au_file] > 0} {
        read_faults $au_file
    }

    if {[file exists $ae_file] && [file size $ae_file] > 0} {
        read_faults $ae_file
    }

    if {[file exists $nd_file] && [file size $nd_file] > 0} {
        read_faults $nd_file
    }

  }

  # Run simulation
  run_simulation -sequential -update
  run_fault_sim -detected_pattern_storage

  # Report Faults 
  set_faults -fault_coverage
  report_faults -summary
  report_summaries cpu_usage

  # Write Fault List
  catch {write_faults ${CIRCUIT}/Partitioning_Flt_Dropping_DT/${CIRCUIT}_pn${n}_DT.flt -class DT -replace} 
  catch {write_faults ${CIRCUIT}/Partitioning_Flt_Dropping_PT/${CIRCUIT}_pn${n}_PT.flt -class PT -replace}
  catch {write_faults ${CIRCUIT}/Partitioning_Flt_Dropping_UD/${CIRCUIT}_pn${n}_UD.flt -class UD -replace}
  catch {write_faults ${CIRCUIT}/Partitioning_Flt_Dropping_AU/${CIRCUIT}_pn${n}_AU.flt -class AU -replace}
  catch {write_faults ${CIRCUIT}/Partitioning_Flt_Dropping_AE/${CIRCUIT}_pn${n}_AE.flt -class AE -replace}
  catch {write_faults ${CIRCUIT}/Partitioning_Flt_Dropping_ND/${CIRCUIT}_pn${n}_ND.flt -class ND -replace}

  #Remove Faults
  remove_faults -all
}
